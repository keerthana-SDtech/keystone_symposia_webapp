\n    };\r\n\r\n    const processSection = (section: any) => {\r\n        if (section.fields) {\r\n            section.fields.forEach(processField);\r\n        }\r\n        if (section.subsections) {\r\n            section.subsections.forEach(processSection);\r\n        }\r\n    };\r\n\r\n    config.forEach(processSection);\r\n\r\n    return z.object(schemaFields);\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\keystone-initial\\keystone-symposia\\src\\features\\sample-feature\\api\\sampleApi.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\keystone-initial\\keystone-symposia\\src\\features\\sample-feature\\components\\SampleComponent.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\keystone-initial\\keystone-symposia\\src\\features\\sample-feature\\hooks\\useSample.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\keystone-initial\\keystone-symposia\\src\\features\\sample-feature\\schemas\\sampleSchemas.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\keystone-initial\\keystone-symposia\\src\\features\\sample-feature\\types\\sample.types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\keystone-initial\\keystone-symposia\\src\\lib\\http.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{